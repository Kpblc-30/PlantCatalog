@page "/products"
@using PlantCatalog.Components.Models
@using PlantCatalog.Components.Services
@inject IProductService ProductService

<h1>Каталог товаров</h1>
<a href="/products/create" class="btn btn-primary">Добавить товар</a>

@if (products == null)
{
    <p>Загрузка...</p>
}
else if (!products.Any())
{
    <p>Товаров пока нет. Добавьте первый!</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Название</th>
                <th>Категория</th>
                <th>Цена</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var product in products)
            {
                <tr>
                    <td>@product.Name</td>
                    <td>@product.Category</td>
                    <td>@product.Price ₽</td>
                    <td>
                        <a href="/products/edit/@product.Id" class="btn btn-sm btn-success">Изменить</a>
                        <button @onclick="() => DeleteProduct(product.Id)" class="btn btn-sm btn-danger">Удалить</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    //  ОБЪЯВЛЕНИЕ СПИСКА (этого не хватало!)
    private List<Product> products = new(); 

    protected override async Task OnInitializedAsync()
    {
        products = await ProductService.GetAllAsync();
    }

    private async Task DeleteProduct(int id)
    {
        await ProductService.DeleteAsync(id);
        products = await ProductService.GetAllAsync();
    }
}